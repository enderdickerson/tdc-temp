          <tr><td>Model (Base)</td><td class="right">22</td><td class="right">$61,898</td><td class="right">$58,499</td><td><div class="margin-bar-container"><div class="margin-bar" style="width:55px"></div><div class="margin-pct">5.49%</div></div></td></tr>
